{
  "name": "theschneider.hair",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0 --mode production",
    "dev:release": "vite --port=4000 --host=0.0.0.0 --mode release",
    "build": "vite build --mode production",
    "build:release": "vite build --mode release",
    "deploy:hosting:release": "pnpm run build:release && firebase deploy --only hosting -P release",
    "deploy:hosting:preview:release": "pnpm run build:release && firebase hosting:channel:deploy preview -P release",
    "deploy:live": "pnpm run deploy:hosting:release",
    "preview": "vite preview --port=3000",
    "lint": "tsc --noEmit",
    "static:legal": "node scripts/render-static-legal-pages.mjs",
    "deploy:rules": "pnpm run deploy:rules:production",
    "deploy:rules:production": "firebase deploy --only firestore:rules -P production",
    "deploy:rules:release": "firebase deploy --only firestore:rules -P release"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "theschneider.hair": "link:"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitejs/plugin-react": "^5.2.0",
    "firebase-tools": "^15.16.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.8.3",
    "vite": "^6.4.2"
  },
  "pnpm": {
    "allowedDeprecatedVersions": {
      "glob": "*",
      "json-ptr": "*",
      "node-domexception": "*",
      "uuid": "*"
    }
  }
}
